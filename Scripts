SELECT 
    Name,
    CreditRating,
    PreferredVendorStatus AS Preferred,
    ActiveFlag AS Active
FROM Purchasing.Vendor
WHERE PreferredVendorStatus = 1
AND ActiveFlag = 1;



SELECT 
    v.Name,
    v.CreditRating,
    v.PreferredVendorStatus AS Preferred,
    v.ActiveFlag AS Active,
    pv.MinOrderQty,
    pv.MaxOrderQty,
    pv.OnOrderQty
FROM Purchasing.Vendor v
LEFT JOIN Purchasing.ProductVendor pv
    ON v.BusinessEntityID = pv.BusinessEntityID
WHERE v.PreferredVendorStatus = 1
AND v.ActiveFlag = 1
AND (pv.OnOrderQty = 0 OR pv.OnOrderQty IS NULL);
